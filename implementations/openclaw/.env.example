# Agentic Stack Configuration
# Copy this file to .env and fill in the values.

# --- Domain Configuration ---
# The domain where n8n will be accessible (e.g., n8n.example.com)
N8N_DOMAIN=n8n.example.com

# The domain where OpenClaw will be accessible (e.g., agent.example.com)
CLAW_DOMAIN=agent.example.com

# Email for Let's Encrypt SSL certificates (Required)
ACME_EMAIL=admin@example.com

# --- Database Secrets ---
# The superuser password for the PostgreSQL container.
# Generate a strong password: openssl rand -base64 32
PG_ROOT_PASSWORD=replace_with_secure_password

# --- Application Secrets ---
# OpenClaw specifics (if needed in future versions)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...

# --- Backup Configuration ---
# Directory on the host where backups will be stored (relative to repo root)
BACKUP_DIR=./backups

# --- ClawSocial Secrets (Optional) ---
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
TWITTER_USERNAME=
TWITTER_PASSWORD=
